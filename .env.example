# ChinaSmartFinds Environment Variables
# Copy this file to .env.local and fill in your values

# Amazon Associates
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=your-tag-here
NEXT_PUBLIC_AMAZON_TRACKING_ID=

# Temu Affiliate
NEXT_PUBLIC_TEMU_AFFILIATE_CODE=

# AliExpress Affiliate
NEXT_PUBLIC_ALIEXPRESS_AFFILIATE_ID=

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
